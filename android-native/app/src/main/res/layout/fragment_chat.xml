<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- 顶栏 — 主分支风格：大而柔和的渐变头像 + 红色纸飞机按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/bg_primary">

        <!-- 角色头像：60dp 粉色径向渐变圆，点击跳转角色资料 -->
        <TextView
            android:id="@+id/tvPersonaAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:gravity="center"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_avatar_soft_pink" />

        <!-- 中间：角色名 + 打字状态（弱化、单行，避免堆叠） -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPersonaName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_base"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvTypingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/text_tertiary"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- 新对话按钮：红色圆形纸飞机 -->
        <ImageButton
            android:id="@+id/btnNewChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_btn_plane"
            android:src="@drawable/ic_send"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="新对话" />
    </LinearLayout>

    <!-- 消息列表 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMessages"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="16dp"
            android:scrollbars="none" />

        <!-- 空状态：居中星号 + 标题 + 提示 -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦"
                android:textSize="48sp"
                android:textColor="@color/text_tertiary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_4"
                android:text="开始对话"
                android:textSize="@dimen/text_xl"
                android:textStyle="bold"
                android:textColor="@color/text_tertiary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2"
                android:text="输入消息开始聊天"
                android:textSize="@dimen/text_base"
                android:textColor="@color/text_disabled" />
        </LinearLayout>
    </FrameLayout>

    <!-- 输入栏 -->
    <LinearLayout
        android:id="@+id/inputBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:background="@color/bg_primary">

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="输入消息..."
            android:textColor="@color/gray_100"
            android:textColorHint="@color/gray_500"
            android:textSize="@dimen/text_base"
            android:paddingHorizontal="@dimen/space_4"
            android:paddingVertical="@dimen/space_3"
            android:maxLines="4"
            android:minHeight="40dp"
            android:inputType="textMultiLine|textCapSentences"
            android:importantForAutofill="no" />

        <TextView
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="@dimen/space_2"
            android:gravity="center"
            android:text="➤"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/bg_send_button" />
    </LinearLayout>
</LinearLayout>
