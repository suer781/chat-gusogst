<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Ambient light overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_ambient_light"
        android:importantForAccessibility="no" />

    <!-- ===================================================
         Main content: header + fragment + bottom nav
         Arranged vertically in a single LinearLayout.
         =================================================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/header_padding_h"
            android:background="@drawable/bg_header">

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/app_name"
                android:textSize="@dimen/text_lg"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Fragment container (takes remaining vertical space) -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Bottom navigation bar -->
        <LinearLayout
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="@dimen/nav_height"
            android:orientation="horizontal"
            android:gravity="center"
            android:clipChildren="false"
            android:background="@color/bg_primary">

            <!-- Chat tab -->
            <LinearLayout
                android:id="@+id/navChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null">
                <ImageView
                    android:id="@+id/navChatIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_chat"
                    android:contentDescription="@string/nav_chat" />
                <TextView
                    android:id="@+id/navChatText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_chat"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/nav_active" />
            </LinearLayout>

            <!-- Persona tab -->
            <LinearLayout
                android:id="@+id/navPersona"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null">
                <ImageView
                    android:id="@+id/navPersonaIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_persona"
                    android:contentDescription="@string/nav_persona" />
                <TextView
                    android:id="@+id/navPersonaText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_persona"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/nav_inactive" />
            </LinearLayout>

            <!-- Providers tab -->
            <LinearLayout
                android:id="@+id/navProviders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null">
                <ImageView
                    android:id="@+id/navProvidersIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_server"
                    android:contentDescription="@string/nav_providers" />
                <TextView
                    android:id="@+id/navProvidersText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_providers"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/nav_inactive" />
            </LinearLayout>

            <!-- Settings tab -->
            <LinearLayout
                android:id="@+id/navSettings"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@null">
                <ImageView
                    android:id="@+id/navSettingsIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="@string/nav_settings" />
                <TextView
                    android:id="@+id/navSettingsText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/nav_settings"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/nav_inactive" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ===================================================
         Navigation active-tab indicator overlay
         
         IMPORTANT: This View is a DIRECT CHILD of the outer
         FrameLayout, NOT a child of bottomNav's LinearLayout.
         
         Why: If placed inside the horizontal LinearLayout, the
         indicator becomes the 5th child and sits to the right
         of all 4 tabs. Using translationX to slide it left is
         fragile — system bar insets shift the LinearLayout's
         children, breaking translationX's reference frame.
         
         As a FrameLayout overlay, the indicator is positioned
         using View.setX() with absolute screen coordinates
         derived from the nav items' on-screen positions.
         See MainActivity.kt → moveIndicator().
         =================================================== -->
    <View
        android:id="@+id/navIndicator"
        android:layout_width="30dp"
        android:layout_height="3dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="6dp"
        android:background="@drawable/bg_nav_indicator"
        android:importantForAccessibility="no" />

</FrameLayout>
